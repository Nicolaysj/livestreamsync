# Dependencies
node_modules/
.pnp
.pnp.js

# Builds / bundles (note: /build holds source build scripts and IS tracked)
dist/
dist-electron/
dist-ssr/
out/
release/
.vite/
*.tsbuildinfo

# Local run output / test artifacts
test-out*/
povsync-output/

# Tauri / Rust
src-tauri/target/
target/
**/*.rs.bk
Cargo.lock.orig

# Bundled / downloaded toolchain binaries (yt-dlp, ffmpeg — fetched at build/first-run)
tools/
bin/
*.exe
*.dll

# Downloaded media — never commit VOD clips or audio extracts.
# NOTE: do NOT add "*.ts" here — it would ignore all TypeScript source.
# Transient MPEG-TS fragments only ever land in the ignored output dirs above.
*.mp4
*.mkv
*.mov
*.webm
*.m4a
*.aac
*.wav
*.flac

# Secrets / local config
.env
.env.*
!.env.example
*.local
cookies.txt
*.cookies

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini
