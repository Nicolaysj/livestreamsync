{
  "name": "livestreamsync",
  "version": "0.1.1",
  "private": true,
  "description": "Multi-POV Twitch + YouTube VOD sync & download tool for video editors",
  "author": "Nicolay Schiøll-Johansen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nicolaysj/livestreamsync.git"
  },
  "homepage": "https://github.com/Nicolaysj/livestreamsync#readme",
  "bugs": {
    "url": "https://github.com/Nicolaysj/livestreamsync/issues"
  },
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev:web": "vite",
    "build:web": "vite build",
    "build:main": "node build/esbuild.mjs",
    "dev": "node build/dev.mjs",
    "start": "electron .",
    "cli": "tsx cli/index.ts",
    "typecheck": "tsc --noEmit",
    "fetch-tools": "node build/fetch-tools.mjs",
    "package": "npm run fetch-tools && npm run build:web && npm run build:main && electron-builder --win"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "live.nixolay.livestreamsync",
    "productName": "LivestreamSync",
    "publish": [
      {
        "provider": "github",
        "owner": "Nicolaysj",
        "repo": "livestreamsync"
      }
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "tools",
        "to": "tools",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build/resources"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/resources/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
